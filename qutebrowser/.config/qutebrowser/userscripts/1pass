#!/usr/bin/env bash

set +e

# JS field injection code from https://github.com/qutebrowser/qutebrowser/blob/main/misc/userscripts/password_fill
javascript_escape() {
    # print the first argument in an escaped way, such that it can safely
    # be used within javascripts double quotes
    # shellcheck disable=SC2001
    sed "s,[\\\\'\"\/],\\\\&,g" <<< "$1"
}

js() {
cat <<EOF
    function isVisible(elem) {
        var style = elem.ownerDocument.defaultView.getComputedStyle(elem, null);
        if (style.getPropertyValue("visibility") !== "visible" ||
            style.getPropertyValue("display") === "none" ||
            style.getPropertyValue("opacity") === "0") {
            return false;
        }
        return elem.offsetWidth > 0 && elem.offsetHeight > 0;
    };
    function hasPasswordField(form) {
        var inputs = form.getElementsByTagName("input");
        for (var j = 0; j < inputs.length; j++) {
            var input = inputs[j];
            if (input.type == "password") {
                return true;
            }
        }
        return false;
    };
    var nativeSetter = Object.getOwnPropertyDescriptor(HTMLInputElement.prototype, 'value').set;
    function fillInput(el, val) {
        try {
            nativeSetter.call(el, val);
            el.dispatchEvent(new Event('input', {bubbles: true}));
            el.dispatchEvent(new Event('change', {bubbles: true}));
        } catch(e) {}
    };
    if(window.location.hostname.indexOf("$(javascript_escape "${URL}")") !== -1) {
        var docs = [document];
        var frames = document.querySelectorAll("iframe");
        for (var f = 0; f < frames.length; f++) {
            try { if (frames[f].contentDocument) docs.push(frames[f].contentDocument); } catch(e) {}
        }
        for (var d = 0; d < docs.length; d++) {
            var doc = docs[d];
            var inputs = doc.querySelectorAll("input[type=password]");
            for (var k = 0; k < inputs.length; k++) {
                fillInput(inputs[k], "$(javascript_escape "${PASSWORD}")");
            }
            var uinputs = doc.querySelectorAll("input[type=text], input[type=email]");
            for (var m = 0; m < uinputs.length; m++) {
                if (isVisible(uinputs[m])) {
                    fillInput(uinputs[m], "$(javascript_escape "${USERNAME}")");
                }
            }
        }
    } else {
        alert("Secrets will not be inserted.\nUrl of this page and the one where the user script was started differ.");
    }
EOF
}

URL=$(echo "$QUTE_URL" | awk -F/ '{print $3}' | sed 's/www.//g')
TOKEN_CACHE="$HOME/.config/qutebrowser/1pass.token"

echo "message-info 'Looking for password for $URL...'" >> "$QUTE_FIFO"

# Validate or acquire session token
if [ -f "$TOKEN_CACHE" ]; then
    TOKEN=$(cat "$TOKEN_CACHE")
    if ! op whoami --account my --session="$TOKEN" > /dev/null 2>&1; then
        TOKEN=$(rofi -dmenu -password -p "1password: " | op signin --account my --raw 2>/dev/null) || TOKEN=""
        echo "$TOKEN" > "$TOKEN_CACHE"
    fi
else
    TOKEN=$(rofi -dmenu -password -p "1password: " | op signin --account my --raw 2>/dev/null) || TOKEN=""
    install -m 600 /dev/null "$TOKEN_CACHE"
    echo "$TOKEN" > "$TOKEN_CACHE"
fi

if [ -z "$TOKEN" ]; then
    echo "message-error '1password: sign in failed'" >> "$QUTE_FIFO"
    exit 1
fi

ITEMS=$(op item list --format=json --account my --session="$TOKEN" 2>/dev/null)
if [ -z "$ITEMS" ]; then
    echo "message-error '1password: failed to list items'" >> "$QUTE_FIFO"
    exit 1
fi

UUID=$(echo "$ITEMS" \
    | jq --arg url "$URL" -r \
        '[.[] | select(.urls != null) | {id, url: .urls[].href}
          | select(.url | test(".*\($url).*"))][0].id') || UUID=""

if [ -z "$UUID" ] || [ "$UUID" == "null" ]; then
    echo "message-error 'No entry found for $URL'" >> "$QUTE_FIFO"
    TITLE=$(echo "$ITEMS" | jq -r '.[].title' | rofi -dmenu -i) || TITLE=""
    if [ -n "$TITLE" ]; then
        UUID=$(echo "$ITEMS" \
            | jq --arg title "$TITLE" -r \
                '[.[] | {id, title} | select(.title | test("\($title)"))][0].id') || UUID=""
    else
        UUID=""
    fi
fi

if [ -n "$UUID" ]; then
    ITEM=$(op item get "$UUID" --format=json --account my --session="$TOKEN" 2>/dev/null)

    PASSWORD=$(echo "$ITEM" | jq -r '.fields[] | select(.id == "password") | .value')

    if [ -n "$PASSWORD" ]; then
        TITLE=$(echo "$ITEM" | jq -r '.title')
        USERNAME=$(echo "$ITEM" | jq -r '.fields[] | select(.id == "username") | .value')

        printjs() {
            js | sed 's,//.*$,,' | tr '\n' ' '
        }
        echo "jseval -q $(printjs)" >> "$QUTE_FIFO"

        TOTP=$(op item get "$UUID" --otp --account my --session="$TOKEN" 2>/dev/null) || TOTP=""
        if [ -n "$TOTP" ]; then
            echo "$TOTP" | wl-copy
            echo "message-info 'Pasted one time password for $TITLE to clipboard'" >> "$QUTE_FIFO"
        fi
    else
        echo "message-error 'No password found for $URL'" >> "$QUTE_FIFO"
    fi
else
    echo "message-error 'Entry not found for $URL'" >> "$QUTE_FIFO"
fi
